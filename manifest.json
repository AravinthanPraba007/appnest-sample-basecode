{
  "platform--version": "2.0",
  "parentProduct": "surveysparrow",
  "location": {
    "full_page_app": {
      "url": "index.html"
    }
  },
  "whitelistedDomains": [
    "https://(.*).signsparrow.com(.*)",
    "https://(.*).surveysparrow.com(.*)",
    "http://(.*).surveysparrow.test(.*)",
    "https://hooks\\.slack\\.com(/.*)?",
    "https://api\\.surveysparrow\\.com(/.*)?",
    "https://api\\.signsparrow\\.com(/.*)?"
  ],
  "productEvents": {
    "onSubmissionComplete": {
      "handler": "onSubmissionComplete"
    }
  },
  "apiFunctions": {
    "getMappings": {
      "timeout": 10
    },
    "saveMapping": {
      "timeout": 15
    }
  },
  "customInstallationFrontend": false,
  "installationParams": {
    "surveysparrow_api_key": {
      "data-bind": "product.api_key",
      "display_name": "surveysparrow API Key",
      "description": "Please enter your surveysparrow API key. You can find it in Settings -> Apps & Integrations",
      "required": true,
      "secure": true,
      "type": "api_key"
    },
    "client_id": {
      "display_name": "Client ID",
      "description": "Please enter your Client ID here",
      "type": "text",
      "required": true
    },
    "client_secret": {
      "display_name": "Client Secret",
      "description": "Please enter your Client Secret here",
      "type": "text",
      "required": true
    },
    "authorize_url": {
      "display_name": "Authorize URL",
      "description": "Please enter your Authorize URL here",
      "type": "text",
      "required": true
    },
    "token_url": {
      "display_name": "Token URL",
      "description": "Please enter your Token URL here",
      "type": "text",
      "required": true
    },
    "account_identifier": {
      "display_name": "Account Identifier",
      "description": "Please enter your Account Identifier here",
      "type": "text",
      "required": true
    },
    "account_type": {
      "display_name": "Choose Setup Method",
      "description": " How would you like to connect to Snowflake?",
      "type": "text",
      "required": true,
      "default_value": "data_sharing"
    }
  },
  "oauth": {
    "googleCalendar": {
      "client_id": "925479924224-8prrlgnil72t6j06bu5a5lqsb6t87t1u.apps.googleusercontent.com",
      "client_secret": "CZVlrgSjqnAq6fM3jVtGdz4q",
      "authorize_url": "https://accounts.google.com/o/oauth2/auth",
      "token_url": "https://oauth2.googleapis.com/token",
      "options": {
        "response_type": "code",
        "access_type": "offline",
        "prompt": "consent",
        "scope": [
          "https://www.googleapis.com/auth/calendar"
        ]
      }
    }
  }
}